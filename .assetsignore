# File da NON caricare come asset statici su Cloudflare Workers.
# Sintassi tipo .gitignore. Vale solo per l'upload degli asset (wrangler deploy).

# Segreti — fondamentale per eventuali deploy lanciati in locale
.env
.env.*

# Dipendenze e stato locale
node_modules/
.git/
.github/
.wrangler/
.claude/
.kiro/
.vscode/
.DS_Store
pnpm-lock.yaml
package-lock.json

# Backend / tooling — non devono essere scaricabili dal dominio pubblico
server.js
package.json
*.config.js
*.config.cjs
*.config.mjs
.eslintrc.json
.prettierrc.json
.prettierignore
.assetsignore
.nojekyll
knip.json
vitest.config.*
wrangler.jsonc
build.js
build-search-index.js
generate-sitemap.js
indexnow-submit.js
chat-config.json

# Sorgenti, pipeline e dati di build
config/
scripts/
src/
templates/
data/
tests/
test-SEO/
docs/
reports/
.claude/
node_modules/

# Artefatti di sviluppo / backup
dist/
*.map
*.log
analysis.txt
*_analysis.txt
check_results.txt
copy_results.txt
contatti-*.txt
tmp_*
_extract_*
