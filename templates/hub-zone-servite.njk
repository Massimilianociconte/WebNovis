{# 
  WebNovis — Hub page template: Zone Servite (trasversale)
  URL: /zone-servite/index.html
  Variables: agenziaFCities, realizzazioneCities, geoServices, cities, site, today, todayFormatted
  
  Designed for 800+ page scale: uses service sections with anchorable IDs.
  When expanding, each section can become a sub-hub (/zone-servite/seo-locale/).
#}
<main>
  <div class="container breadcrumb">
    <a href="/">Home</a>
    <span class="separator">/</span>
    <span class="current-page">Zone Servite</span>
  </div>

  <section class="service-page-hero">
    <div class="container">
      <span class="section-tag">{{ totalIndexablePages }} pagine locali indicizzabili</span>
      <h1>Pagine locali WebNovis per zona e servizio</h1>
      <p class="answer-capsule"><strong>WebNovis</strong> dichiara una rete operativa di {{ networkCoverageCount }} territori serviti da Rho. Questo indice elenca separatamente {{ totalIndexablePages }} landing locali approvate per l'indicizzazione: {{ agenziaCount }} per Agenzia Web, {{ realizzazioneCount }} per Realizzazione Siti Web e le restanti per servizi specifici.</p>
      <div class="hub-intro-grid">
        {% for scope in coverageScopes %}
        <article class="hub-scope-card">
          <strong>{{ scope.label }}</strong>
          <span class="hub-scope-count">{{ scope.count }} {{ scope.helper }}</span>
          <p>{{ scope.description }}</p>
        </article>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="service-detail hub-atlas">
    <div class="container">
      <div class="hub-atlas-header">
        <div>
          <h2>Selezione di landing Agenzia Web indicizzabili</h2>
          <p>Indice visuale delle pagine approvate per l'indicizzazione. Questa selezione non equivale all'intera area operativa dichiarata da WebNovis.</p>
        </div>
        <a href="/agenzia-web/" style="color:var(--primary-light);font-weight:600">→ Apri l'hub delle landing Agenzia Web</a>
      </div>
      <div class="hub-city-grid">
        {% for city in featuredCities %}
        <a href="/agenzia-web-{{ city.slug }}.html" class="hub-city-card" title="Agenzia Web {{ city.name }}">
          {% if city.avatarSrc %}
          <span class="hub-city-avatar"><img src="{{ city.avatarSrc }}" alt="" width="52" height="52" loading="lazy" decoding="async"></span>
          {% else %}
          <span class="hub-city-avatar hub-city-avatar--fallback" data-initials="{{ city.name | replace(' ', '') | upper | truncate(2, true, '') }}"></span>
          {% endif %}
          <span class="hub-city-content">
            <span class="hub-city-name">{{ city.name }}</span>
            <span class="hub-city-meta">{{ city.province }} · {{ city.distanzaSede }}</span>
          </span>
        </a>
        {% endfor %}
      </div>
    </div>
  </section>

  {# ═══ Agenzia Web section ═══ #}
  <section class="service-detail" id="agenzia-web">
    <div class="container">
      <h2><a href="/agenzia-web/" style="color:var(--white);text-decoration:none">Agenzia Web</a> — {{ agenziaCount }} landing indicizzabili</h2>
      <p>Questo elenco comprende soltanto le pagine Agenzia Web ammesse all'indicizzazione, non tutti i territori della rete operativa.</p>
      <div class="hub-city-grid hub-city-grid--compact">
        {% for city in agenziaCities %}
        <a href="/agenzia-web-{{ city.slug }}.html" class="hub-city-card hub-city-card--sm" title="Agenzia Web {{ city.name }}">
          {% if city.avatarSrc %}
          <span class="hub-city-avatar"><img src="{{ city.avatarSrc }}" alt="" width="40" height="40" loading="lazy" decoding="async"></span>
          {% else %}
          <span class="hub-city-avatar hub-city-avatar--fallback" data-initials="{{ city.name | replace(' ', '') | upper | truncate(2, true, '') }}"></span>
          {% endif %}
          <span class="hub-city-content">
            <span class="hub-city-name">{{ city.name }}</span>
          </span>
        </a>
        {% endfor %}
      </div>
      <p style="margin-top:1rem"><a href="/agenzia-web/" style="color:var(--primary-light);font-weight:600">→ Consulta l'hub Agenzia Web indicizzabile</a></p>
    </div>
  </section>

  {# ═══ Realizzazione Siti Web section ═══ #}
  <section class="service-detail" id="realizzazione-siti-web" style="background:rgba(255,255,255,.01)">
    <div class="container">
      <h2><a href="/realizzazione-siti-web/" style="color:var(--white);text-decoration:none">Realizzazione Siti Web</a> — {{ realizzazioneCount }} landing indicizzabili</h2>
      <p>Siti web professionali con codice custom, SEO locale integrata e design su misura. La sezione mostra solo le landing locali ammesse all'indicizzazione.</p>
      <div class="hub-city-grid hub-city-grid--compact">
        {% for city in realizzazioneCities %}
        <a href="/realizzazione-siti-web-{{ city.slug }}.html" class="hub-city-card hub-city-card--sm" title="Siti Web {{ city.name }}">
          {% if city.avatarSrc %}
          <span class="hub-city-avatar"><img src="{{ city.avatarSrc }}" alt="" width="40" height="40" loading="lazy" decoding="async"></span>
          {% else %}
          <span class="hub-city-avatar hub-city-avatar--fallback" data-initials="{{ city.name | replace(' ', '') | upper | truncate(2, true, '') }}"></span>
          {% endif %}
          <span class="hub-city-content">
            <span class="hub-city-name">{{ city.name }}</span>
          </span>
        </a>
        {% endfor %}
      </div>
      <p style="margin-top:1rem"><a href="/realizzazione-siti-web/" style="color:var(--primary-light);font-weight:600">→ Consulta l'hub delle landing Realizzazione Siti Web</a></p>
    </div>
  </section>

  {# ═══ Service×City sections (one per service, anchorable ID) ═══ #}
  {% for service in geoServices %}
  <section class="service-detail" id="{{ service.slug }}"{% if loop.index % 2 == 0 %} style="background:rgba(255,255,255,.01)"{% endif %}>
    <div class="container">
      <h2>{{ service.name }} — landing locali indicizzabili</h2>
      <p>{{ service.shortDesc }} Da €{{ service.priceFrom }}{{ service.priceUnit if service.priceUnit }}. Sono elencate solo le combinazioni servizio-città approvate.</p>
      <div class="hub-city-grid hub-city-grid--compact">
        {% for city in serviceCities[service.slug] %}
        <a href="/{{ service.slug }}-{{ city.slug }}.html" class="hub-city-card hub-city-card--sm" title="{{ service.shortName }} a {{ city.name }}">
          {% if city.avatarSrc %}
          <span class="hub-city-avatar"><img src="{{ city.avatarSrc }}" alt="" width="40" height="40" loading="lazy" decoding="async"></span>
          {% else %}
          <span class="hub-city-avatar hub-city-avatar--fallback" data-initials="{{ city.name | replace(' ', '') | upper | truncate(2, true, '') }}"></span>
          {% endif %}
          <span class="hub-city-content">
            <span class="hub-city-name">{{ city.name }}</span>
          </span>
        </a>
        {% endfor %}
      </div>
      <p class="service-scope-note">Ogni comune mostrato qui ha una landing servizio dedicata e approvata per l'indicizzazione.</p>
    </div>
  </section>
  {% endfor %}

  <section class="cta-inline">
    <div class="container">
      <h2>Cerchi un servizio specifico per il tuo comune?</h2>
      <p>Contattaci per un preventivo gratuito. Rispondiamo entro 24 ore.</p>
      <a href="/contatti.html" class="btn btn-large btn-primary">
        <span>Contattaci Ora</span>
        <svg height="20" viewBox="0 0 20 20" width="20" fill="none"><path d="M4 10H16M16 10L10 4M16 10L10 16" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg>
      </a>
    </div>
  </section>
</main>
