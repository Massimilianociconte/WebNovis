{# 
  WebNovis — Nunjucks template for service×city pSEO pages
  URL pattern: /{service.slug}-{city.slug}.html
  Example: /seo-locale-lainate.html, /ecommerce-arese.html
  
  Variables: city, service, nearCitiesData, relatedServicePages, relatedCityPages, today, site
#}
<main>
  <div class="container breadcrumb">
    <a href="/">Home</a>
    <span class="separator">/</span>
    <a href="/zone-servite/#{{ service.slug }}">{{ service.shortName }}</a>
    <span class="separator">/</span>
    <span class="current-page">{{ service.shortName }} a {{ city.name }}</span>
  </div>

  {# ═══ HERO — Answer capsule (GEO: first 60 words = direct answer) ═══ #}
  <section class="service-page-hero">
    <div class="container">
      <span class="section-tag">{{ seo.heroTag }}</span>
      <h1>{{ seo.heroH1 }}</h1>
      <p class="answer-capsule">{{ seo.heroCapsule | safe }}</p>
      {% if seo.heroHighlights and seo.heroHighlights | length > 0 %}
      <div style="display:flex;flex-wrap:wrap;gap:.75rem;justify-content:center;max-width:860px;margin:0 auto 2rem">
        {% for item in seo.heroHighlights %}
        <div style="min-width:160px;padding:.85rem 1rem;border-radius:14px;border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.03)">
          <strong style="display:block;color:var(--white);font-size:1rem">{{ item.value }}</strong>
          <span style="display:block;color:var(--gray-light);font-size:.82rem;opacity:.85;margin-top:.15rem">{{ item.label }}</span>
        </div>
        {% endfor %}
      </div>
      {% endif %}
      <a href="/contatti.html" class="btn btn-large btn-primary">
        <span>Richiedi Preventivo Gratuito</span>
        <svg height="20" viewBox="0 0 20 20" width="20" fill="none"><path d="M4 10H16M16 10L10 4M16 10L10 16" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg>
      </a>
      <p style="margin-top:1.5rem;font-size:.85rem;opacity:.5">
        <time datetime="{{ today }}">{{ todayFormatted }}</time>
        &nbsp;·&nbsp; Sede: Via S. Giorgio 2, 20017 Rho MI
      </p>
    </div>
  </section>

  {# ═══ SECTION 1 — Service description specific to this city ═══ #}
  <section class="service-detail">
    <div class="container">
      <h2>{{ seo.sectionTitle }}</h2>
      <p>{{ seo.sectionIntro }}{% if city.distanzaSedeKm <= 10 %} La nostra sede è a soli {{ city.distanzaSede }} da {{ city.name }}, quindi possiamo confrontarci rapidamente anche di persona.{% endif %}</p>
      <p>Questa pagina è il focus locale su {{ city.name }}. Per deliverable completi, impostazione del servizio e panoramica più ampia puoi vedere <a href="{{ seo.primaryPageUrl }}" style="color:var(--primary-light)">{{ seo.primaryPageLabel }}</a>.</p>
      {% if city.localContext and city.localContext.settoriChiave %}
      <p>A {{ city.name }}{% if city.population %} ({{ city.population | localeNumber }} abitanti){% endif %} i settori che beneficiano maggiormente di {{ service.name | lower }} includono: <strong>{{ city.localContext.settoriChiave | join('</strong>, <strong>') }}</strong>.</p>
      {% endif %}
      <div class="service-grid">
        <div class="service-card-mini">
          <h3>Prezzo</h3>
          <p><strong>Da €{{ service.priceFrom }}{{ service.priceUnit if service.priceUnit }}</strong> — preventivo personalizzato gratuito entro 24 ore per la tua attività a {{ city.name }}.</p>
        </div>
        <div class="service-card-mini">
          <h3>Tempi</h3>
          <p><strong>{{ service.timeEstimate }}</strong> — dal brief iniziale alla consegna, con un unico interlocutore dedicato.</p>
        </div>
        <div class="service-card-mini">
          <h3>Ideale per</h3>
          <p>{{ service.idealFor }}. Ogni progetto è personalizzato per il mercato locale di {{ city.name }}.</p>
        </div>
      </div>
    </div>
  </section>

  {# ═══ SECTION 2 — Why WebNovis for this service in this city ═══ #}
  <section class="service-detail" style="background:rgba(255,255,255,.01)">
    <div class="container">
      <h2>{{ seo.whyTitle }}</h2>
      <div class="service-grid">
        {% for card in seo.whyCards %}
        <div class="service-card-mini">
          <h3>{{ card.title }}</h3>
          <p>{{ card.text }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {# ═══ SECTION 2b — How we work for this service ═══ #}
  <section class="service-detail">
    <div class="container">
      <h2>{{ seo.processTitle }}</h2>
      <p>{{ seo.processIntro }}</p>
      <div class="service-grid">
        {% for step in seo.processSteps %}
        <div class="service-card-mini">
          <h3>{{ step.title }}</h3>
          <p>{{ step.text }}</p>
        </div>
        {% endfor %}
      </div>
      {% if city.localContext and city.localContext.settoriChiave %}
      <p style="margin-top:1.5rem">A {{ city.name }}{% if city.population %} ({{ city.population | localeNumber }} abitanti){% endif %}, {{ service.name | lower }} è particolarmente rilevante per i settori: <strong>{{ city.localContext.settoriChiave | join('</strong>, <strong>') }}</strong>.</p>
      {% endif %}
    </div>
  </section>

  {# ═══ SECTION 3 — Local market context (AI-enriched when available) ═══ #}
  <section class="service-detail">
    <div class="container">
      <h2>{{ service.name }} nel contesto di {{ city.name }}</h2>
      {% if aiContent %}
      {{ aiContent | safe }}
      {% else %}
      {% if city.localContext %}
      <p>{{ city.localContext.tessutoEconomico }}</p>
      <p>{{ city.localContext.opportunitaDigitale }}</p>
      {% endif %}
      <p>Le attività di {{ city.name }} che investono in {{ service.name | lower }} possono intercettare la domanda locale e distinguersi dai competitor. Con prezzi a partire da <strong>€{{ service.priceFrom }}{{ service.priceUnit if service.priceUnit }}</strong> e tempi di <strong>{{ service.timeEstimate }}</strong>, WebNovis offre un percorso concreto verso la crescita digitale.</p>
      {% endif %}
      {% if city.localContext and city.localContext.highlights %}
      <p>Punti di riferimento del territorio: {% for hl in city.localContext.highlights %}<strong>{{ hl }}</strong>{% if not loop.last %}, {% endif %}{% endfor %}.</p>
      {% endif %}
    </div>
  </section>

  {# ═══ SECTION 3b — Local data & competitive insight (unique per city) ═══ #}
  {% if dataPoints or competitiveInsight %}
  <section class="service-detail" style="background:rgba(255,255,255,.01)">
    <div class="container">
      <h2>{{ service.shortName }} a {{ city.name }}: il contesto competitivo locale</h2>
      {% if dataPoints %}
      <div style="display:flex;flex-wrap:wrap;gap:.75rem;margin-bottom:1.5rem">
        {% if dataPoints.estimatedLocalBusinesses %}
        <div style="min-width:160px;padding:.85rem 1rem;border-radius:14px;border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.03)">
          <strong style="display:block;color:var(--white);font-size:1.1rem">{{ dataPoints.estimatedLocalBusinesses | localeNumber }}+</strong>
          <span style="display:block;color:var(--gray-light);font-size:.82rem;opacity:.85;margin-top:.15rem">Attività a {{ city.name }}</span>
        </div>
        {% endif %}
        {% if dataPoints.competitionLevel %}
        <div style="min-width:160px;padding:.85rem 1rem;border-radius:14px;border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.03)">
          <strong style="display:block;color:var(--white);font-size:1.1rem">{{ dataPoints.competitionLevel | capitalize }}</strong>
          <span style="display:block;color:var(--gray-light);font-size:.82rem;opacity:.85;margin-top:.15rem">Competizione digitale</span>
        </div>
        {% endif %}
        {% if dataPoints.digitalMaturityScore %}
        <div style="min-width:160px;padding:.85rem 1rem;border-radius:14px;border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.03)">
          <strong style="display:block;color:var(--white);font-size:1.1rem">{{ dataPoints.digitalMaturityScore | capitalize }}</strong>
          <span style="display:block;color:var(--gray-light);font-size:.82rem;opacity:.85;margin-top:.15rem">Maturità digitale</span>
        </div>
        {% endif %}
      </div>
      {% if dataPoints.topSearchQueries and dataPoints.topSearchQueries | length > 0 %}
      <p>Le ricerche più frequenti nella zona includono: {% for q in dataPoints.topSearchQueries %}<em>"{{ q }}"</em>{% if not loop.last %}, {% endif %}{% endfor %}. Posizionarsi su queste query significa intercettare domanda reale e convertirla in contatti.</p>
      {% endif %}
      {% endif %}
      {% if competitiveInsight %}
      <p>{{ competitiveInsight }}</p>
      {% endif %}
    </div>
  </section>
  {% endif %}

  {# ═══ SECTION 3c — Decision framework for competitive services ═══ #}
  {% if seo.decisionFrameworkCards and seo.decisionFrameworkCards | length > 0 %}
  <section class="service-detail">
    <div class="container">
      <h2>{{ seo.decisionFrameworkTitle }}</h2>
      {% if seo.decisionFrameworkIntro %}
      <p>{{ seo.decisionFrameworkIntro }}</p>
      {% endif %}
      <div class="service-grid">
        {% for card in seo.decisionFrameworkCards %}
        <div class="service-card-mini">
          <h3>{{ card.title }}</h3>
          <p>{{ card.text }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>
  {% endif %}

  {# ═══ SECTION 3d — Deliverables and scope clarity ═══ #}
  {% if seo.deliverablesCards and seo.deliverablesCards | length > 0 %}
  <section class="service-detail" style="background:rgba(255,255,255,.01)">
    <div class="container">
      <h2>{{ seo.deliverablesTitle }}</h2>
      {% if seo.deliverablesIntro %}
      <p>{{ seo.deliverablesIntro }}</p>
      {% endif %}
      <div class="service-grid">
        {% for card in seo.deliverablesCards %}
        <div class="service-card-mini">
          <h3>{{ card.title }}</h3>
          <p>{{ card.text }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>
  {% endif %}

  {# ═══ SECTION 3e — Query coverage cues for local commercial intent ═══ #}
  {% if seo.intentQueries and seo.intentQueries | length > 0 %}
  <section class="service-detail">
    <div class="container">
      <h2>{{ seo.intentQueriesTitle }}</h2>
      {% if seo.intentQueriesIntro %}
      <p>{{ seo.intentQueriesIntro }}</p>
      {% endif %}
      <p>
        {% for query in seo.intentQueries %}
        <em>"{{ query }}"</em>{% if not loop.last %}, {% endif %}
        {% endfor %}
      </p>
    </div>
  </section>
  {% endif %}

  {# ═══ SECTION 4 — Comparison table (GEO: +115% AI citation visibility) ═══ #}
  <section class="service-detail" style="background:rgba(255,255,255,.01)">
    <div class="container">
      <h2>Tutti i servizi WebNovis per {{ city.name }}</h2>
      <div style="overflow-x:auto">
        <table style="width:100%;border-collapse:collapse;margin:1.5rem 0;font-size:.95rem">
          <thead>
            <tr style="border-bottom:2px solid rgba(255,255,255,.1)">
              <th scope="col" style="text-align:left;padding:12px 16px;color:var(--white);font-weight:600">Servizio</th>
              <th scope="col" style="text-align:left;padding:12px 16px;color:var(--white);font-weight:600">Prezzo da</th>
              <th scope="col" style="text-align:left;padding:12px 16px;color:var(--white);font-weight:600">Tempi</th>
            </tr>
          </thead>
          <tbody>
            {% for svc in allCoreServices %}
            <tr style="border-bottom:1px solid rgba(255,255,255,.05){% if svc.slug == service.slug %};background:rgba(91,106,174,.1){% endif %}">
              <td style="padding:12px 16px;color:var(--primary-light);font-weight:{% if svc.slug == service.slug %}700{% else %}600{% endif %}">{% if svc.slug == service.slug %}{{ svc.shortName }} ←{% else %}<a href="/{{ svc.slug }}-{{ city.slug }}.html" style="color:var(--primary-light);text-decoration:none">{{ svc.shortName }}</a>{% endif %}</td>
              <td style="padding:12px 16px;color:var(--gray-light)">€{{ svc.priceFrom }}{{ svc.priceUnit if svc.priceUnit }}</td>
              <td style="padding:12px 16px;color:var(--gray-light)">{{ svc.timeEstimate }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      <p style="font-size:.85rem;color:var(--gray-light);opacity:.7">Prezzi IVA esclusa. Preventivo gratuito personalizzato entro 24 ore. Ultimo aggiornamento: {{ todayFormatted }}.</p>
    </div>
  </section>

  {# ═══ SECTION 5 — FAQ (GEO: question-based headings) ═══ #}
  {% if faqs | length > 0 %}
  <section class="service-detail">
    <div class="container">
      <h2>Domande Frequenti — {{ service.shortName }} a {{ city.name }}</h2>
      {% for faq in faqs %}
      <details class="faq-item">
        <summary>{{ faq.q }}</summary>
        <p>{{ faq.a | safe }}</p>
      </details>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# ═══ SECTION 6 — Related pages: same service in nearby cities ═══ #}
  {% if relatedCityPages | length > 0 %}
  <section class="service-detail" style="background:rgba(255,255,255,.01)">
    <div class="container">
      <h2>{{ service.shortName }} nei comuni vicini a {{ city.name }}</h2>
      <p>
        {% for rp in relatedCityPages %}{% if loop.index <= 3 %}
        <a href="{{ rp.url }}" style="color:var(--primary-light)">{{ rp.label }}</a> ({{ rp.distance }}){% if loop.index < 3 and relatedCityPages | length > loop.index %},{% endif %}
        {% endif %}{% endfor %}
      </p>
    </div>
  </section>
  {% endif %}

  {# ═══ SECTION 7 — Related pages: other services in same city ═══ #}
  {% if relatedServicePages | length > 0 %}
  <section class="service-detail">
    <div class="container">
      <h2>Altri servizi WebNovis a {{ city.name }}</h2>
      <p>
        {% for rp in relatedServicePages %}{% if loop.index <= 6 %}
        <a href="{{ rp.url }}" style="color:var(--primary-light)">{{ rp.label }}</a>{% if loop.index < 6 and relatedServicePages | length > loop.index %},{% endif %}
        {% endif %}{% endfor %}
        — <a href="/agenzia-web-{{ city.slug }}.html" style="color:var(--primary-light)">Tutti i servizi a {{ city.name }}</a>
      </p>
    </div>
  </section>
  {% endif %}

  {# ═══ CTA ═══ #}
  <section class="cta-inline">
    <div class="container">
      <h2>{{ seo.ctaTitle }}</h2>
      <p>{{ seo.ctaCopy }}</p>
      <a href="/contatti.html" class="btn btn-large btn-primary">
        <span>Contattaci Ora</span>
        <svg height="20" viewBox="0 0 20 20" width="20" fill="none"><path d="M4 10H16M16 10L10 4M16 10L10 16" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg>
      </a>
    </div>
  </section>
</main>
