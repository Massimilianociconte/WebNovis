# ========== GEMINI API KEYS (4 chiavi su 4 progetti Google separati) ==========
# Ogni chiave ha la propria quota free tier INDIPENDENTE:
#   - 1.500 richieste/giorno per progetto
#   - 1M token/min per progetto (32K tok/min per gemini-2.5-flash)
# Crea le chiavi su: https://aistudio.google.com/apikey
# IMPORTANTE: usa un progetto Google diverso per ogni chiave!

# KEY 1 — Chatbot Weby (server.js, runtime, ~50-200 req/giorno)
GEMINI_API_KEY_CHAT=your-gemini-chat-api-key-here

# KEY 2 — Search bar AI (server.js, runtime, ~20-100 req/giorno)
GEMINI_API_KEY_SEARCH=your-gemini-search-api-key-here

# KEY 3 — Auto blog writer (blog/auto-writer.js, cron notturno, 1-3 req/giorno)
GEMINI_API_KEY_WRITER=your-gemini-writer-api-key-here

# KEY 4 + KEY 5 — pSEO batch content (scripts/generate-ai-content.js, burst 45-100 req)
# Queste 2 chiavi sono COMPLETAMENTE ISOLATE da CHAT/SEARCH/WRITER.
# Round-robin automatico: quando KEY 4 viene rate-limitata, passa a KEY 5 e viceversa.
# NON c'è mai fallback sulle chiavi runtime — zero rischio di impatto sul sito live.
GEMINI_API_KEY_PSEO=your-gemini-pseo-key-1-here
GEMINI_API_KEY_PSEO_2=your-gemini-pseo-key-2-here

# ========== BREVO (Newsletter) ==========
# Crea un account gratuito su: https://www.brevo.com
# Genera una API key da: https://app.brevo.com/settings/keys/api
# Free tier: 100.000 contatti, 9.000 email/mese (300/giorno)
BREVO_API_KEY=xkeysib-your-api-key-here

# Brevo List ID (ID della lista contatti newsletter)
# Crea una lista in Brevo > Contacts > Lists, poi copia l'ID numerico
BREVO_LIST_ID=2

# Brevo Sender Email (deve essere verificata in Brevo > Senders)
BREVO_SENDER_EMAIL=newsletter@webnovis.com
BREVO_SENDER_NAME=WebNovis

# Email dove ricevere le notifiche dei lead (form 404, etc.)
# Default: hello@webnovis.com
BREVO_NOTIFICATION_EMAIL=hello@webnovis.com

# Groq API Key (per newsletter AI + fallback auto blog writer)
# Crea un account gratuito su: https://console.groq.com
# Free tier: 6.000 richieste/giorno, Llama 3.3 70B
GROQ_API_KEY=gsk_your-api-key-here

# Newsletter Admin Secret (protegge l'endpoint di invio manuale)
# Genera una stringa casuale sicura (almeno 32 caratteri)
NEWSLETTER_ADMIN_SECRET=change-this-to-a-random-secret-string-32chars

# ========== INDEXNOW (Indicizzazione istantanea Bing, Yandex, Naver, etc.) ==========
# Chiave generata per la verifica ownership del dominio.
# Il file {key}.txt deve essere nella root del sito (già incluso nel repo).
# Per ruotare la chiave: genera una nuova, aggiorna qui e crea il nuovo file .txt
INDEXNOW_KEY=8531a1fa-b8b0-4136-8741-b5895865d3c4

# Server Port
PORT=3000
